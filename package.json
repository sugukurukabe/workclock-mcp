{
  "name": "sugukuru-workclock-mcp",
  "version": "1.0.1",
  "description": "Sugukuru WorkClock MCP — local-first Pomodoro and work-time logging MCP server for developers. Natural Japanese commands, append-only JSONL ledger, auto-generated Markdown, MCP Apps timer UI.",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "workclock-mcp": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Sugukuru",
  "homepage": "https://github.com/sugukurukabe/workclock-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sugukurukabe/workclock-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/sugukurukabe/workclock-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pomodoro",
    "time-tracking",
    "worklog",
    "productivity",
    "markdown",
    "obsidian",
    "cursor",
    "claude",
    "chatgpt",
    "ai"
  ],
  "scripts": {
    "dev": "tsx watch src/main.ts --stdio",
    "dev:stdio": "tsx watch src/main.ts --stdio",
    "dev:http": "tsx watch src/main.ts --http",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "vite build",
    "serve": "node dist/main.js --http",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-stdio.mjs",
    "lint": "eslint src web tests",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run build && npm run test && npm run smoke",
    "prepublishOnly": "npm run build",
    "inspect:stdio": "npx @modelcontextprotocol/inspector node dist/main.js --stdio",
    "inspect:http": "npx @modelcontextprotocol/inspector http://127.0.0.1:3002/mcp"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/express": "2.0.0-alpha.2",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "express": "^4.21.2",
    "nanoid": "^5.1.5",
    "pino": "^9.6.0",
    "proper-lockfile": "^4.1.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.1",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^4.1.8"
  }
}
